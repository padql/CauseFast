{
  "expo": {
    "name": "Kas Acara",
    "slug": "patungan-app",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bendahara.patungan"
    },
    "android": {
      "package": "com.bendahara.patungan",
      "permissions": []
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-updates"
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 30000,
      "checkAutomatically": "NEVER",
      "url": "https://u.expo.dev/PASTE_PROJECT_ID_HERE"
    },
    "extra": {
      "eas": {
        "projectId": "PASTE_PROJECT_ID_HERE"
      }
    }
  }
}
